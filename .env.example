# Copy to .env and fill in your values
# cp .env.example .env

# ── Identity ──────────────────────────────────────────────────────────────────
CLONE_NAME=Will

# ── LLM (HuggingFace model ID — must fit in ~4GB VRAM with 4-bit quant) ──────
LLM_MODEL_ID=microsoft/Phi-3-mini-4k-instruct
# Alternatives: mistralai/Mistral-7B-Instruct-v0.3, Qwen/Qwen2.5-3B-Instruct

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ── TTS ───────────────────────────────────────────────────────────────────────
TTS_REF_AUDIO=data/media/voice_ref/reference.wav

# ── Video (SadTalker) ─────────────────────────────────────────────────────────
SADTALKER_DIR=third_party/SadTalker
REFERENCE_IMAGE=data/media/reference_photo.jpg

# ── HuggingFace token (needed for gated models like Mistral/Llama) ────────────
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Services ──────────────────────────────────────────────────────────────────
API_BASE=http://localhost:8000
GRADIO_PORT=7860
